rules_version = '2';

// ============================================================
// vb-116 Firestore rules v4 — CONTRACT.md v4 §4 invariants.
// 기본 = deny. capability code 문서는 get만 공개, 본체 쓰기는 역할/소유권으로 제한.
// ============================================================
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- helpers ----------
    function authed() { return request.auth != null; }
    function roleDoc(uid) {
      return get(/databases/$(database)/documents/roles/$(uid)).data;
    }
    function hasRole() {
      return authed() && exists(/databases/$(database)/documents/roles/$(request.auth.uid));
    }
    function isMaster() {
      return hasRole() && roleDoc(request.auth.uid).role == 'master';
    }
    // admin = 주최측 권한. master는 포함관계상 admin 권한을 가진다.
    function isAdmin() {
      return hasRole() && (roleDoc(request.auth.uid).role == 'admin' || roleDoc(request.auth.uid).role == 'master');
    }
    function isTeacher() {
      return hasRole() && roleDoc(request.auth.uid).role == 'teacher';
    }
    function isSchoolTeacher(eventId, schoolId) {
      return authed()
        && exists(/databases/$(database)/documents/events/$(eventId)/schools/$(schoolId)/teachers/$(request.auth.uid));
    }
    function canManageSchool(eventId, schoolId) {
      return isAdmin() || isSchoolTeacher(eventId, schoolId);
    }
    function eventData(eventId) {
      return get(/databases/$(database)/documents/events/$(eventId)).data;
    }
    function eventNotFrozen(eventId) {
      let e = eventData(eventId);
      return !e.frozen;
    }
    function eventAttemptOpen(eventId) {
      let e = eventData(eventId);
      return !e.frozen && request.time >= e.startsAt && request.time <= e.endsAt;
    }
    function timestampField(name) {
      return request.resource.data[name] is timestamp;
    }
    function validSlot(slot) {
      return slot in ['c1', 'c2', 'c3'];
    }
    function validMetrics(metrics) {
      return metrics.keys().hasOnly([
          'missionId', 'environment', 'solveMode', 'successRate',
          'averageTimeSec', 'stars', 'blockCount'
        ])
        && metrics.missionId is int
        && metrics.environment is string
        && metrics.solveMode in ['ai', 'block']
        && metrics.successRate is number
        && metrics.successRate >= 0
        && metrics.successRate <= 1
        && (metrics.averageTimeSec is number || metrics.averageTimeSec == null)
        && metrics.stars is int
        && metrics.blockCount is int;
    }

    // ---------- capability mappings ----------
    function mappingKeys() {
      return ['eventId', 'schoolId', 'classId', 'participantId', 'createdAt'];
    }
    function validRecoveryMapping(hash) {
      let data = request.resource.data;
      let participantPath = /databases/$(database)/documents/events/$(data.eventId)/schools/$(data.schoolId)/classes/$(data.classId)/participants/$(data.participantId);
      return request.resource.data.keys().hasOnly(mappingKeys())
        && timestampField('createdAt')
        && existsAfter(participantPath)
        && getAfter(participantPath).data.ownerUid == request.auth.uid
        && getAfter(participantPath).data.recoveryHash == hash;
    }

    match /joinCodes/{code} {
      allow get: if true;
      allow list: if false;
      allow create: if validJoinCodeMapping(request.resource.data)
        && canManageSchool(request.resource.data.eventId, request.resource.data.schoolId);
      allow update: if false;
      allow delete: if validJoinCodeMapping(resource.data)
        && canManageSchool(resource.data.eventId, resource.data.schoolId);
    }
    match /teacherCodes/{code} {
      allow get: if true;
      allow list: if false;
      allow create, update, delete: if isAdmin();
    }
    match /recoveryCodes/{hash} {
      allow get: if true;
      allow list: if false;
      allow create: if authed() && validRecoveryMapping(hash);
      allow update, delete: if false;
      match /claims/{uid} {
        allow get: if authed() && uid == request.auth.uid;
        allow list: if false;
        allow create: if authed() && uid == request.auth.uid
          && request.resource.data.keys().hasOnly(['claimedAt'])
          && timestampField('claimedAt');
        allow update, delete: if false;
      }
    }

    // ---------- roles / master ----------
    function validAdminInviteCreate() {
      return request.resource.data.keys().hasOnly(['createdBy', 'usedBy', 'createdAt'])
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.usedBy == null
        && timestampField('createdAt');
    }
    function validAdminInviteRedeem() {
      return authed()
        && resource.data.usedBy == null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usedBy'])
        && request.resource.data.usedBy == request.auth.uid;
    }
    function validAdminRoleFromInvite(uid) {
      return authed()
        && uid == request.auth.uid
        && request.resource.data.keys().hasOnly(['role', 'email', 'inviteCode', 'createdAt'])
        && request.resource.data.role == 'admin'
        && (!('email' in request.resource.data) || request.resource.data.email is string)
        && timestampField('createdAt')
        && getAfter(/databases/$(database)/documents/adminInvites/$(request.resource.data.inviteCode)).data.usedBy == request.auth.uid;
    }
    function validTeacherRoleCreate(uid) {
      return authed()
        && uid == request.auth.uid
        && request.resource.data.role == 'teacher'
        && request.resource.data.keys().hasOnly(['role', 'email', 'createdAt', 'code', 'eventId', 'schoolId', 'schoolPaths'])
        && (!('email' in request.resource.data) || request.resource.data.email is string)
        && timestampField('createdAt')
        && request.resource.data.schoolPaths is list
        && getAfter(/databases/$(database)/documents/events/$(request.resource.data.eventId)/schools/$(request.resource.data.schoolId)/teachers/$(request.auth.uid)).data.code
           == request.resource.data.code;
    }
    function validTeacherRoleUpdate(uid) {
      return authed()
        && uid == request.auth.uid
        && resource.data.role == 'teacher'
        && request.resource.data.role == 'teacher'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role', 'email', 'schoolPaths'])
        && (!('email' in request.resource.data) || request.resource.data.email is string);
    }
    function validTeacherRoleAdminUpdate(uid) {
      return isAdmin()
        && resource.data.role == 'teacher'
        && request.resource.data.role == 'teacher'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['schoolPaths']);
    }
    function validOwnRoleEmailUpdate(uid) {
      return authed()
        && uid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['email'])
        && request.resource.data.email is string;
    }
    function validMasterRoleCreate() {
      return request.resource.data.keys().hasOnly(['role', 'email', 'inviteCode', 'createdAt'])
        && request.resource.data.role in ['teacher', 'admin']
        && (!('email' in request.resource.data) || request.resource.data.email is string)
        && timestampField('createdAt');
    }

    match /adminInvites/{code} {
      allow get: if authed();
      allow list: if isMaster();
      allow create: if isMaster() && validAdminInviteCreate();
      allow update: if validAdminInviteRedeem();
      allow delete: if isMaster();
    }
    match /roles/{uid} {
      allow get: if authed() && (uid == request.auth.uid || isMaster());
      allow list: if isMaster();
      allow create: if validAdminRoleFromInvite(uid)
        || validTeacherRoleCreate(uid)
        || (isMaster() && validMasterRoleCreate());
      allow update: if validTeacherRoleUpdate(uid)
        || validTeacherRoleAdminUpdate(uid)
        || validOwnRoleEmailUpdate(uid);
      allow delete: if isMaster() || (authed() && uid == request.auth.uid);
    }

    // ---------- document validators ----------
    function validEventWrite(eventId) {
      return request.resource.data.keys().hasOnly([
          'id', 'name', 'startsAt', 'endsAt', 'challenges',
          'attemptsPerChallenge', 'visibility', 'scoringVersion', 'frozen', 'createdAt'
        ])
        && request.resource.data.id == eventId
        && request.resource.data.name is string
        && timestampField('startsAt')
        && timestampField('endsAt')
        && request.resource.data.challenges is list
        && request.resource.data.challenges.size() == 3
        && ((request.resource.data.attemptsPerChallenge is int
              && request.resource.data.attemptsPerChallenge >= 1
              && request.resource.data.attemptsPerChallenge <= 10)
            || request.resource.data.attemptsPerChallenge == null)
        && request.resource.data.visibility in ['code-only', 'public-masked', 'public']
        && request.resource.data.scoringVersion == 'v2'
        && request.resource.data.frozen is bool
        && timestampField('createdAt');
    }
    function validEventUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'name', 'startsAt', 'endsAt', 'attemptsPerChallenge', 'frozen', 'visibility'
        ])
        && request.resource.data.name is string
        && request.resource.data.startsAt is timestamp
        && request.resource.data.endsAt is timestamp
        && ((request.resource.data.attemptsPerChallenge is int
              && request.resource.data.attemptsPerChallenge >= 1
              && request.resource.data.attemptsPerChallenge <= 10)
            || request.resource.data.attemptsPerChallenge == null)
        && request.resource.data.visibility in ['code-only', 'public-masked', 'public']
        && request.resource.data.frozen is bool;
    }
    function validSchoolWrite(eventId, schoolId) {
      return request.resource.data.keys().hasOnly([
          'id', 'eventId', 'name', 'state', 'zone', 'teacherCode', 'createdAt'
        ])
        && request.resource.data.id == schoolId
        && request.resource.data.eventId == eventId
        && request.resource.data.name is string
        && request.resource.data.teacherCode is string
        && timestampField('createdAt');
    }
    function validClassWrite(eventId, schoolId, classId) {
      return request.resource.data.keys().hasOnly(['id', 'eventId', 'schoolId', 'name', 'joinCode', 'joinActive', 'createdAt'])
        && request.resource.data.id == classId
        && request.resource.data.eventId == eventId
        && request.resource.data.schoolId == schoolId
        && request.resource.data.name is string
        && request.resource.data.joinCode is string
        && request.resource.data.joinActive is bool
        && timestampField('createdAt');
    }
    function validClassJoinSettingsUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['joinCode', 'joinActive'])
        && request.resource.data.joinCode is string
        && request.resource.data.joinActive is bool;
    }
    function validJoinCodeMapping(data) {
      return data.keys().hasOnly(['eventId', 'schoolId', 'classId', 'schoolName', 'className', 'state', 'zone', 'createdAt'])
        && data.eventId is string
        && data.schoolId is string
        && data.classId is string
        && data.className is string
        && data.createdAt is timestamp;
    }
    function validParticipantCreate(eventId, schoolId, classId, participantId) {
      let classInfo = get(/databases/$(database)/documents/events/$(eventId)/schools/$(schoolId)/classes/$(classId)).data;
      return request.resource.data.keys().hasOnly([
          'id', 'eventId', 'schoolId', 'classId', 'name', 'grade', 'publicId',
          'status', 'ownerUid', 'recoveryHash', 'registeredAt', 'statusHistory'
        ])
        && request.resource.data.id == participantId
        && request.resource.data.eventId == eventId
        && request.resource.data.schoolId == schoolId
        && request.resource.data.classId == classId
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.statusHistory == []
        && timestampField('registeredAt')
        && eventNotFrozen(eventId)
        && (!('joinActive' in classInfo) || classInfo.joinActive == true); // 결손 = 활성 (v3 이전 문서 호환)
    }
    function validTeacherStatusBoardUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && request.resource.data.status in ['pending', 'approved', 'rejected'];
    }
    function validTeacherParticipantStatusUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'statusHistory'])
        && request.resource.data.status in ['pending', 'approved', 'rejected']
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.recoveryHash == resource.data.recoveryHash;
    }
    function validOwnerWithdraw() {
      return authed()
        && resource.data.ownerUid == request.auth.uid
        && resource.data.status in ['pending', 'approved']
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'statusHistory'])
        && request.resource.data.status == 'withdrawn'
        && request.resource.data.statusHistory is list;
    }
    function validOwnerRevive() {
      return authed()
        && resource.data.ownerUid == request.auth.uid
        && resource.data.status == 'withdrawn'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'statusHistory', 'name', 'grade'])
        && request.resource.data.status == 'pending'
        && request.resource.data.name is string
        && request.resource.data.statusHistory is list;
    }

    // ---------- attempts / board ----------
    function validAttemptCreate(eventId, schoolId, classId, participantId, attemptId) {
      let participant = get(/databases/$(database)/documents/events/$(eventId)/schools/$(schoolId)/classes/$(classId)/participants/$(participantId)).data;
      let e = eventData(eventId);
      return request.resource.data.keys().hasOnly(['slot', 'attemptNo', 'metrics', 'submittedAt'])
        && participant.ownerUid == request.auth.uid
        && !(participant.status in ['rejected', 'withdrawn'])
        && validSlot(request.resource.data.slot)
        && attemptId == participantId + '_' + request.resource.data.slot + '_' + string(request.resource.data.attemptNo)
        && request.resource.data.attemptNo is int
        && request.resource.data.attemptNo >= 1
        && (e.attemptsPerChallenge == null || request.resource.data.attemptNo <= e.attemptsPerChallenge)
        && validMetrics(request.resource.data.metrics)
        && timestampField('submittedAt')
        && eventAttemptOpen(eventId);
    }
    function boardAttempt(eventId, schoolId, classId, participantId, slot) {
      return get(/databases/$(database)/documents/events/$(eventId)/schools/$(schoolId)/classes/$(classId)/participants/$(participantId)/attempts/$(participantId + '_' + slot + '_' + string(request.resource.data.bests[slot].attemptNo))).data;
    }
    function validBoardBest(eventId, schoolId, classId, participantId, slot) {
      let best = request.resource.data.bests[slot];
      let attempt = boardAttempt(eventId, schoolId, classId, participantId, slot);
      return best.keys().hasOnly(['attemptNo', 'timeSec', 'metrics'])
        && best.attemptNo is int
        && best.timeSec is number
        && validMetrics(best.metrics)
        && attempt.slot == slot
        && attempt.attemptNo == best.attemptNo
        && attempt.metrics == best.metrics
        && attempt.metrics.successRate == 1
        && attempt.metrics.averageTimeSec is number
        && best.timeSec == attempt.metrics.averageTimeSec;
    }
    function validPresentBest(eventId, schoolId, classId, participantId, slot) {
      return !request.resource.data.bests.keys().hasAny([slot])
        || validBoardBest(eventId, schoolId, classId, participantId, slot);
    }
    function existingBestKeptOrImproved(slot) {
      return !resource.data.bests.keys().hasAny([slot])
        || (request.resource.data.bests.keys().hasAny([slot])
            && request.resource.data.bests[slot].timeSec <= resource.data.bests[slot].timeSec);
    }
    function validBoardWrite(eventId, schoolId, classId, participantId) {
      let participant = getAfter(/databases/$(database)/documents/events/$(eventId)/schools/$(schoolId)/classes/$(classId)/participants/$(participantId)).data;
      return request.resource.data.keys().hasOnly([
          'participantId', 'publicId', 'name', 'status', 'bests', 'updatedAt'
        ])
        && participant.ownerUid == request.auth.uid
        && request.resource.data.participantId == participantId
        && request.resource.data.publicId == participant.publicId
        && request.resource.data.name == participant.name
        && request.resource.data.status == participant.status
        && request.resource.data.bests is map
        && request.resource.data.bests.keys().hasOnly(['c1', 'c2', 'c3'])
        && validPresentBest(eventId, schoolId, classId, participantId, 'c1')
        && validPresentBest(eventId, schoolId, classId, participantId, 'c2')
        && validPresentBest(eventId, schoolId, classId, participantId, 'c3')
        && timestampField('updatedAt');
    }
    function validBoardUpdate(eventId, schoolId, classId, participantId) {
      return validBoardWrite(eventId, schoolId, classId, participantId)
        && request.resource.data.bests.keys().hasAll(resource.data.bests.keys())
        && existingBestKeptOrImproved('c1')
        && existingBestKeptOrImproved('c2')
        && existingBestKeptOrImproved('c3');
    }

    // ---------- main tree ----------
    match /events/{eventId} {
      allow get: if true;
      allow list: if isAdmin();
      allow create: if isAdmin() && validEventWrite(eventId);
      allow update: if isAdmin() && validEventUpdate();
      allow delete: if false;

      match /schools/{schoolId} {
        allow get: if isSchoolTeacher(eventId, schoolId) || isAdmin();
        allow list: if isAdmin();
        allow create, update: if isAdmin() && validSchoolWrite(eventId, schoolId);
        allow delete: if false;

        match /teachers/{uid} {
          allow get: if authed() && (uid == request.auth.uid || isAdmin());
          allow list: if isAdmin();
          allow create: if authed() && uid == request.auth.uid
            && request.resource.data.keys().hasOnly(['code', 'email', 'boundAt'])
            && (!('email' in request.resource.data) || request.resource.data.email is string)
            && request.resource.data.code
               == get(/databases/$(database)/documents/events/$(eventId)/schools/$(schoolId)).data.teacherCode
            && timestampField('boundAt');
          // v5: email 백필 — 본인이 email 필드만 갱신 가능
          allow update: if authed() && uid == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['email'])
            && request.resource.data.email is string;
          allow delete: if isAdmin() || (authed() && uid == request.auth.uid);
        }

        match /classes/{classId} {
          allow get: if true;
          allow list: if isSchoolTeacher(eventId, schoolId) || isAdmin();
          allow create: if canManageSchool(eventId, schoolId) && validClassWrite(eventId, schoolId, classId);
          allow update: if (isAdmin() && validClassWrite(eventId, schoolId, classId))
            || (canManageSchool(eventId, schoolId) && validClassJoinSettingsUpdate());
          allow delete: if false;

          match /board/{participantId} {
            allow get, list: if true;
            allow create: if authed() && validBoardWrite(eventId, schoolId, classId, participantId);
            allow update: if (authed() && validBoardUpdate(eventId, schoolId, classId, participantId))
              || ((isSchoolTeacher(eventId, schoolId) || isAdmin()) && validTeacherStatusBoardUpdate());
            allow delete: if isSchoolTeacher(eventId, schoolId) || isAdmin();
          }

          match /participants/{participantId} {
            allow get: if authed()
              && (resource.data.ownerUid == request.auth.uid
                  || isSchoolTeacher(eventId, schoolId) || isAdmin());
            allow list: if isSchoolTeacher(eventId, schoolId) || isAdmin()
              || (authed() && resource.data.ownerUid == request.auth.uid);
            allow create: if authed() && validParticipantCreate(eventId, schoolId, classId, participantId);
            allow update: if ((isSchoolTeacher(eventId, schoolId) || isAdmin()) && validTeacherParticipantStatusUpdate())
              || validOwnerWithdraw()
              || validOwnerRevive()
              || (authed()
                  && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ownerUid'])
                  && request.resource.data.ownerUid == request.auth.uid
                  && exists(/databases/$(database)/documents/recoveryCodes/$(resource.data.recoveryHash)/claims/$(request.auth.uid)));
            allow delete: if false;

            match /attempts/{attemptId} {
              allow get, list: if authed()
                && (get(/databases/$(database)/documents/events/$(eventId)/schools/$(schoolId)/classes/$(classId)/participants/$(participantId)).data.ownerUid == request.auth.uid
                    || isSchoolTeacher(eventId, schoolId) || isAdmin());
              allow create: if authed() && validAttemptCreate(eventId, schoolId, classId, participantId, attemptId);
              allow update, delete: if false;
            }
          }
        }
      }
    }
  }
}
